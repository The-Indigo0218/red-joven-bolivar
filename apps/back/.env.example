DATABASE_HOST=localhost
# El docker-compose de la raíz expone Postgres en 5433 (5432 suele estar ocupado).
# Si usás otro Postgres en 5432, cambialo acá.
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=red_joven_bolivar
PORT=3000

# IA — Gemini (Google AI Studio, capa gratuita).
# Dejá GEMINI_API_KEY vacío para usar la heurística por reglas (sin IA).
# Pegá tu key (la generás en https://aistudio.google.com/apikey) para activarla.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
